# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ENCRYPTION_KEY: Used to encrypt long-lived Instagram access tokens at rest.
ENCRYPTION_KEY="MY_ENCRYPTION_KEY"

# META_CLIENT_ID: Your Meta App Client ID
META_CLIENT_ID="MY_META_CLIENT_ID"

# META_CLIENT_SECRET: Your Meta App Client Secret
META_CLIENT_SECRET="MY_META_CLIENT_SECRET"

# META_VERIFY_TOKEN: Token for Meta Webhook Verification
META_VERIFY_TOKEN="MY_META_VERIFY_TOKEN"
